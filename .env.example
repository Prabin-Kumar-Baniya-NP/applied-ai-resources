# Copy this file to `.env` and fill in your real values.
#   cp .env.example .env
#
# The scripts load these automatically via python-dotenv.

# OpenAI API key — used for BOTH text embeddings and answer generation.
OPENAI_API_KEY=sk-your-key-here

# Redis connection string. Your local Redis is already running here.
REDIS_URL=redis://localhost:6379

# Postgres connection string (used by the RAG Triad example with pgvector).
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://appliedaiuser:your-password@localhost:5432/appliedaidb

# Neo4j connection (used by the Graph RAG project: novamart-supply-graph).
# Defaults match the project's docker-compose.yml.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=novamartgraph
