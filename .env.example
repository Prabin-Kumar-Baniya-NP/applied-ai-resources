# Copy this file to `.env` and fill in your real values.
#   cp .env.example .env
#
# The scripts load these automatically via python-dotenv.

# OpenAI API key — used for BOTH text embeddings and answer generation.
OPENAI_API_KEY=sk-your-key-here

# Redis connection string. Your local Redis is already running here.
REDIS_URL=redis://localhost:6379
